# .env.example
# Основні налаштування сервера
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Режими роботи: 'server' (headless, доступний у мережі) або 'app' (веб-клієнт в браузері)
MODE=app

# Публічний тунель для постійного посилання: 'none', 'ngrok', 'cloudflare'
TUNNEL=none

# Налаштування Ngrok (для отримання БЕЗКОШТОВНОГО постійного посилання)
# Зареєструйтесь на ngrok.com -> Domains -> Створіть 1 безкоштовний домен
NGROK_DOMAIN=your-static-domain.ngrok-free.app
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Автозапуск десктопного Electron-застосунку при запуску у режимі 'app' (True / False)
START_DESKTOP=False

# Налаштування ШІ
OLLAMA_URL=http://localhost:11434/api/generate
MODEL_NAME=gemma4:unrestricted
SEARCH_API_KEY=dev-secret-key

# API ключі для пошуку (опціонально)
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SHODAN_API_KEY=

# Налаштування проксі (для Darknet/Tor)
ENABLE_PROXY=False
PROXY_URL=socks5://127.0.0.1:9050

